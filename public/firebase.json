{
  "firestore": {
    "rules": "config/firestore.rules",
    "indexes": "config/firestore.indexes.json"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "**/tests/**",
      "**/vercel-stripe-backend/**",
      "**/netlify-stripe-backend/**",
      "**/.venv/**",
      "**/*.py",
      "**/*.pyc",
      "**/requirements*.txt",
      "**/__pycache__/**",
      "**/.git/**",
      "**/.github/**",
      "**/README.md",
      "**/CHANGELOG.md",
      "**/LICENSE",
      "**/package.json",
      "**/package-lock.json",
      "**/yarn.lock",
      "**/.env*",
      "**/.DS_Store"
    ]
  }
} 